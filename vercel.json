{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "*.jpg", "use": "@vercel/static" },
    { "src": "*.jpeg", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.gif", "use": "@vercel/static" },
    { "src": "*.webp", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/og-preview.jpg", "dest": "/og-preview.jpg" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "\\.(jpg|jpeg|png|gif|webp|svg|ico)$", "dest": "/$0" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
